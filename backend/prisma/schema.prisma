generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. SAAS KİMLİK & FİRMA YÖNETİMİ
// ==========================================
enum PlanType {
  TRIAL
  BASIC
  PRO
}

enum DataSource {
  MANUAL
  TRENDYOL
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

model Tenant {
  id               String       @id @default(uuid())
  companyName      String       // Eski: store_name
  industry         String?      
  subscriptionPlan PlanType     @default(TRIAL)
  status           TenantStatus @default(ACTIVE)
  taxInfo          Json?
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users            User[]
  integrations     TenantIntegration[]
  products         Product[]
  orders           Order[]
  financialRecords FinancialLedger[]
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  
  fullName     String
  email        String   @unique
  phoneNumber  String?
  passwordHash String
  role         UserRole @default(OWNER)
  
  createdAt    DateTime @default(now())
}

// ==========================================
// 2. ENTEGRASYON YÖNETİMİ
// ==========================================
enum Platform {
  TRENDYOL
  HEPSIBURADA
}

model TenantIntegration {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  
  platform            Platform @default(TRENDYOL)
  sellerId            String   
  
  encryptedApiKey     String   
  encryptedApiSecret  String   
  
  webhookId           String?  
  webhookApiKey       String?  
  isActive            Boolean  @default(true)
  
  lastSyncAt          DateTime?
  updatedAt           DateTime @updatedAt
}

// ==========================================
// 3. KATALOG & STOK (ÜRÜNLER)
// ==========================================
model Product {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  
  barcode        String
  sku            String
  name           String
  source         DataSource @default(MANUAL)

  salePrice      Decimal  @db.Decimal(10, 2)
  listPrice      Decimal? @db.Decimal(10, 2)
  costPrice      Decimal? @db.Decimal(10, 2)
  vatRate        Int      @default(20)
  stockQuantity  Int      @default(0)
  attributes     Json?    
  
  lastSyncAt     DateTime?
  
  orderItems     OrderItem[]
  
  @@unique([tenantId, barcode])
}

// ==========================================
// 4. SİPARİŞ, İADE VE KARGO OPERASYONU
// ==========================================
enum OrderType {
  STANDARD
  MICRO_EXPORT
  FOREIGN_BROKERAGE
}

enum LabelStatus {
  NONE
  LABEL_PENDING
  LABEL_READY
}

model Order {
  id                  String   @id @default(uuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  
  platform            Platform @default(TRENDYOL)
  source              DataSource @default(MANUAL)
  orderNumber         String   @unique
  orderType           OrderType @default(STANDARD)
  countryCode         String   @default("TR")
  status              String   // CREATED, PICKING, SHIPPED vb.
  
  cargoTrackingNumber String?
  cargoProvider       String?
  shippingLabels      Json?    
  labelStatus         LabelStatus @default(NONE)
  
  returnStatus        String?
  returnRequestedAt   DateTime?
  
  orderDate           DateTime @default(now())

  items               OrderItem[]
  financialLedger     FinancialLedger? 
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  order               Order    @relation(fields: [orderId], references: [id])
  
  productId           String?
  product             Product? @relation(fields: [productId], references: [id])
  
  quantity            Int
  price               Decimal  @db.Decimal(10, 2)
  
  commissionRate      Decimal? @db.Decimal(10, 2)
  commissionAmount    Decimal? @db.Decimal(10, 2)
  shippingCost        Decimal? @db.Decimal(10, 2)
  netProfit           Decimal? @db.Decimal(10, 2)

  returns             ReturnItem[]
}

model ReturnItem {
  id                  String   @id @default(uuid()) 
  
  claimId             String   
  claimLineItemId     String   @unique 
  
  orderItemId         String
  orderItem           OrderItem @relation(fields: [orderItemId], references: [id])
  
  claimItemStatus     String   
  customerNote        String?
  
  createdAt           DateTime @default(now()) 
  updatedAt           DateTime @updatedAt
}

// ==========================================
// 5. MUHASEBE VE FİNANS ZEKASI
// ==========================================
enum SettlementStatus {
  PENDING
  PAID
}

model FinancialLedger {
  id                  String   @id @default(uuid())
  tenantId            String   // Çoklu kiracı mimarisi için güvenlik eklentisi
  tenant              Tenant   @relation(fields: [tenantId], references: [id])

  transactionId       String   @unique 
  
  orderId             String?  @unique
  order               Order?   @relation(fields: [orderId], references: [id])
  
  expectedPaymentDate DateTime?
  settlementStatus    SettlementStatus @default(PENDING)
  
  sellerRevenue       Decimal  @default(0.0) @db.Decimal(10, 2) 
  commissionAmount    Decimal  @default(0.0) @db.Decimal(10, 2) 
  cargoExpense        Decimal  @default(0.0) @db.Decimal(10, 2) 
  returnCargoExpense  Decimal  @default(0.0) @db.Decimal(10, 2) 
  netProfit           Decimal  @default(0.0) @db.Decimal(10, 2) 
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}