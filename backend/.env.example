# Veritabanı
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ventahub_db?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Backend
PORT=3001

# Şifreleme anahtarı (64 karakter hex, openssl rand -hex 32 ile üret)
ENCRYPTION_KEY=your_64_char_hex_key_here

# Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Natural Language API (opsiyonel)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
